<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Inventory Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container mt-5">
    <h2 class="mb-4">📦 Inventory Management Dashboard</h2>

    <div class="row mb-3">
        <div class="col">
            <div th:each="p : ${products}" th:if="${p.isLowStock()}" class="alert alert-warning alert-dismissible fade show" role="alert">
                <strong>⚠️ Alert: Low Stock!</strong> '<span th:text="${p.name}"></span>' has dropped below minimum threshold! Only <span th:text="${p.quantity}"></span> left.
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card p-4 shadow-sm mb-4">
                <h5>Product Entry</h5>
                <hr>
                <div class="mb-3">
                    <label class="form-label text-primary font-weight-bold">Simulate Scanner Field</label>
                    <input type="text" id="scannerInput" class="form-control" placeholder="Scan barcode here..." autofocus>
                </div>
                <form th:action="@{/product/save}" th:object="${newProduct}" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Barcode Number</label>
                        <input type="text" id="barcodeField" th:field="*{barcode}" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Product Name</label>
                        <input type="text" id="nameField" th:field="*{name}" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quantity</label>
                        <input type="number" id="qtyField" th:field="*{quantity}" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Unit Price ($)</label>
                        <input type="number" step="0.01" id="priceField" th:field="*{price}" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Min Threshold Level</label>
                        <input type="number" id="minField" th:field="*{minStockLevel}" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Save Item</button>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card p-4 shadow-sm">
                <h5>Inventory Stocks</h5>
                <hr>
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Barcode</th>
                            <th>Product Name</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="p : ${products}">
                            <td th:text="${p.barcode}"></td>
                            <td th:text="${p.name}"></td>
                            <td th:text="${p.quantity}"></td>
                            <td th:text="'$' + ${p.price}"></td>
                            <td>
                                <span th:if="${p.isLowStock()}" class="badge bg-danger">Critical</span>
                                <span th:unless="${p.isLowStock()}" class="badge bg-success">Good</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    // Intercepts scanner 'Enter' actions to populate the input form
    document.getElementById('scannerInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            let scannedValue = this.value.trim();
            if (scannedValue) {
                fetch('/product/scan/' + scannedValue)
                    .then(res => res.json())
                    .then(data => {
                        if (data) {
                            document.getElementById('barcodeField').value = data.barcode;
                            document.getElementById('nameField').value = data.name;
                            document.getElementById('qtyField').value = data.quantity;
                            document.getElementById('priceField').value = data.price;
                            document.getElementById('minField').value = data.minStockLevel;
                        } else {
                            document.getElementById('barcodeField').value = scannedValue;
                            document.getElementById('nameField').value = '';
                            document.getElementById('qtyField').value = '';
                            document.getElementById('priceField').value = '';
                            document.getElementById('minField').value = '';
                        }
                    }).catch(err => console.log(err));
                this.value = '';
            }
        }
    });
</script>
</body>
</html>
